# Bot identity
BASE_URL=https://bot.example.com
USERNAME=botname
REALNAME=Bot Display Name
SUMMARY=A short bio. <a href="">HTML links allowed</a>.
BIRTHDAY=2024-01-01T00:00:00Z
LANGUAGE=en

# Profile images (relative paths to media/ directory, or full URLs)
AVATAR=
BANNER=

# Posting password (bcrypt hash — generate with: php -r "echo password_hash('yourpass', PASSWORD_BCRYPT);")
PASSWORD=

# RSA keys (generate with: php bin/keygen.php)
# Newlines escaped as \n on a single line
KEY_PRIVATE=
KEY_PUBLIC=

# Logging
MAX_LOGS=2048

# Monitoring — comma-separated
MONITOR_HASHTAGS=WordPress,WordPressSecurity,WPSec,InfoSec
MONITOR_INSTANCES=mastodon.social,infosec.exchange,phpc.social,wptoots.social
MONITOR_KEYWORDS=vulnerability,CVE,exploit,hardening,wp-config,brute force
MONITOR_INTERVAL=3600

# Reporting
REPORT_FREQUENCY=weekly
WEBHOOK_URL=
